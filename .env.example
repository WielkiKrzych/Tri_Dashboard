# Tri_Dashboard Environment Variables
# Copy this file to .env and fill in your values

# OpenWeatherMap API Key (required for weather-based TSS corrections)
# Get your free API key at: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_api_key_here

# Optional: Cache directory location (defaults to .cache/)
# CACHE_DIR=.cache

# Optional: Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO

# Optional: ML Model directory (defaults to models/)
# MODEL_DIR=models
